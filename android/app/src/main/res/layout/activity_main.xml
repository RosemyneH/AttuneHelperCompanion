<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pumpkin_bg"
    android:orientation="vertical">

    <ScrollView
        android:id="@+id/main_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="@dimen/space_lg"
        android:paddingEnd="@dimen/space_lg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/space_lg"
            android:paddingBottom="@dimen/space_lg">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Ahc.Card.Highlight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_xl">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.08"
                        android:text="@string/home_eyebrow"
                        android:textAllCaps="true"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="@color/pumpkin_primary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:text="@string/home_title"
                        android:textAppearance="?attr/textAppearanceHeadlineMedium"
                        android:textColor="@color/pumpkin_text" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:text="@string/home_subtitle"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/pumpkin_text_muted" />

                    <TextView
                        android:id="@+id/text_tree_badge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_lg"
                        android:text="@string/no_tree_yet"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/pumpkin_text" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/section_catalog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Ahc.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_lg">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/section_catalog"
                            android:textAppearance="?attr/textAppearanceTitleLarge"
                            android:textColor="@color/pumpkin_text" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:text="@string/section_catalog_help"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/pumpkin_text_muted" />

                        <EditText
                            android:id="@+id/edit_addon_search"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_md"
                            android:backgroundTint="@color/pumpkin_outline"
                            android:hint="@string/catalog_search_hint"
                            android:importantForAutofill="no"
                            android:inputType="text|textNoSuggestions"
                            android:minHeight="48dp"
                            android:singleLine="true"
                            android:textColor="@color/pumpkin_text"
                            android:textColorHint="@color/pumpkin_text_muted" />

                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:scrollbars="none">

                            <LinearLayout
                                android:id="@+id/layout_category_filters"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal" />
                        </HorizontalScrollView>

                        <TextView
                            android:id="@+id/text_catalog_count"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_md"
                            android:textAppearance="?attr/textAppearanceLabelLarge"
                            android:textColor="@color/pumpkin_primary" />

                        <LinearLayout
                            android:id="@+id/layout_addon_catalog"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:orientation="vertical" />

                        <TextView
                            android:id="@+id/text_addon_empty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_md"
                            android:text="@string/catalog_empty"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="@color/pumpkin_text_muted"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Ahc.Card.Highlight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_lg">

                        <TextView
                            android:id="@+id/text_addon_selected_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/catalog_install_ready"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="@color/pumpkin_text" />

                        <TextView
                            android:id="@+id/text_addon_selected_meta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/pumpkin_text_muted" />

                        <TextView
                            android:id="@+id/text_addon_selected_description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="@color/pumpkin_text_muted" />

                        <TextView
                            android:id="@+id/text_addon_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/pumpkin_success" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_install_addon"
                            style="@style/Widget.Ahc.Button"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_md"
                            android:text="@string/download_install" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_sync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Ahc.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_lg">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/section_library"
                            android:textAppearance="?attr/textAppearanceTitleLarge"
                            android:textColor="@color/pumpkin_text" />

                        <TextView
                            android:id="@+id/text_tree_uri"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:text="@string/no_tree_yet"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/pumpkin_text_muted" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_pick_tree"
                            style="@style/Widget.Ahc.Button.Tonal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_md"
                            android:text="@string/choose_synastria_folder" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_scan_snapshot"
                            style="@style/Widget.Ahc.Button.Tonal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:text="@string/scan_attune_snapshot" />

                        <TextView
                            android:id="@+id/text_scan_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/pumpkin_text_muted" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Ahc.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_lg">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/section_attunes"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="@color/pumpkin_text" />

                        <TextView
                            android:id="@+id/text_attune_line"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:fontFamily="monospace"
                            android:textColor="@color/pumpkin_text_muted"
                            android:textSize="13sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Ahc.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_lg">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/section_sync"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="@color/pumpkin_text" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:text="@string/section_sync_help"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/pumpkin_text_muted" />

                        <EditText
                            android:id="@+id/edit_sync_code"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_md"
                            android:backgroundTint="@color/pumpkin_outline"
                            android:gravity="top|start"
                            android:hint="@string/paste_code_hint"
                            android:importantForAutofill="no"
                            android:inputType="text|textMultiLine|textNoSuggestions"
                            android:minLines="3"
                            android:textColor="@color/pumpkin_text"
                            android:textColorHint="@color/pumpkin_text_muted" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_import_code"
                            style="@style/Widget.Ahc.Button"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_md"
                            android:text="@string/import_code" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_export_code"
                            style="@style/Widget.Ahc.Button.Tonal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:text="@string/export_code" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_copy_code"
                            style="@style/Widget.Ahc.Button.Text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/copy_to_clipboard" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_qr_today"
                            style="@style/Widget.Ahc.Button.Tonal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:text="@string/show_qr_today" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_scan_qr"
                            style="@style/Widget.Ahc.Button.Tonal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:text="@string/scan_qr" />

                        <ImageView
                            android:id="@+id/image_qr"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="@dimen/space_md"
                            android:adjustViewBounds="true"
                            android:contentDescription="@string/qr_code" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_transfer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_nfc"
                    style="@style/Widget.Ahc.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_lg">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/section_nfc"
                            android:textAppearance="?attr/textAppearanceTitleLarge"
                            android:textColor="@color/pumpkin_text" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:text="@string/section_nfc_help"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/pumpkin_text_muted" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_nfc_prepare"
                            style="@style/Widget.Ahc.Button"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_md"
                            android:text="@string/nfc_prepare_push" />

                        <TextView
                            android:id="@+id/text_nfc_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/pumpkin_text_muted" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_play"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Ahc.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_lg">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/section_play"
                            android:textAppearance="?attr/textAppearanceTitleLarge"
                            android:textColor="@color/pumpkin_text" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:text="@string/section_play_help"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/pumpkin_text_muted" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_play_winlator"
                            style="@style/Widget.Ahc.Button"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_md"
                            android:text="@string/open_winlator" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_open_winlator"
                            style="@style/Widget.Ahc.Button.Tonal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:text="@string/android_open_winlator_project" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:text="@string/android_see_docs"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/pumpkin_text_muted" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_bar_height"
        android:background="@color/pumpkin_surface_high"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_sm"
        android:paddingEnd="@dimen/space_sm">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_nav_catalog"
            style="@style/Widget.Ahc.Button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_margin="@dimen/space_xs"
            android:layout_weight="1"
            android:text="@string/bottom_catalog" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_nav_sync"
            style="@style/Widget.Ahc.Button.Text"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_margin="@dimen/space_xs"
            android:layout_weight="1"
            android:text="@string/bottom_sync" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_nav_transfer"
            style="@style/Widget.Ahc.Button.Text"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_margin="@dimen/space_xs"
            android:layout_weight="1"
            android:text="@string/bottom_transfer" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_nav_play"
            style="@style/Widget.Ahc.Button.Text"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_margin="@dimen/space_xs"
            android:layout_weight="1"
            android:text="@string/bottom_play" />
    </LinearLayout>
</LinearLayout>
