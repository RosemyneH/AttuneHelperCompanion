<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/ahc_mobile_bg"
    android:orientation="horizontal">

    <com.google.android.material.navigationrail.NavigationRailView
        android:id="@+id/navigation_rail"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:background="@drawable/ahc_rail_bg"
        android:minWidth="72dp"
        android:paddingTop="@dimen/space_sm"
        app:itemActiveIndicatorStyle="@style/Widget.Ahc.Rail.ActiveIndicator"
        app:itemIconSize="24dp"
        app:itemIconTint="@color/bottom_nav_item_tint"
        app:itemTextColor="@color/bottom_nav_item_tint"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

    <ScrollView
        android:id="@+id/main_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="@dimen/content_padding_compact"
        android:paddingEnd="@dimen/content_padding_compact"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/space_xs"
            android:paddingBottom="@dimen/space_sm">

            <LinearLayout
                android:id="@+id/section_catalog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/text_tree_badge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="@string/tree_missing_short"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="@color/ahc_text_muted" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/layout_category_filters"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:chipSpacingHorizontal="@dimen/catalog_filter_chip_spacing_h"
                        app:chipSpacingVertical="0dp"
                        app:selectionRequired="true"
                        app:singleLine="true"
                        app:singleSelection="true" />
                </HorizontalScrollView>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Ahc.TextField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:hint="@string/catalog_search_hint"
                    app:expandedHintEnabled="true"
                    app:hintTextColor="@color/ahc_text_muted"
                    app:startIconDrawable="@drawable/ic_search_24"
                    app:startIconMinSize="24dp"
                    app:startIconTint="@color/ahc_text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_addon_search"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:importantForAutofill="no"
                        android:inputType="text|textNoSuggestions"
                        android:minHeight="44dp"
                        android:singleLine="true"
                        android:textColor="@color/ahc_text"
                        android:textColorHint="@color/ahc_text_muted" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/text_catalog_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="@color/ahc_text_muted" />

                <TextView
                    android:id="@+id/text_addon_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:visibility="gone"
                    android:textAppearance="?attr/textAppearanceBodySmall" />

                <LinearLayout
                    android:id="@+id/layout_addon_catalog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/text_addon_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:gravity="center"
                    android:text="@string/catalog_empty"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/ahc_text_muted"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_sync"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Ahc.Card.Highlight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_md">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/section_sync"
                            android:textAppearance="?attr/textAppearanceTitleLarge"
                            android:textColor="@color/ahc_cyan" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:text="@string/section_sync_help"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/ahc_text" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_scan_qr"
                            style="@style/Widget.Ahc.Button"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_md"
                            android:text="@string/scan_qr" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_qr_today"
                            style="@style/Widget.Ahc.Button.Tonal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:text="@string/show_qr_today" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_qr_multi"
                            style="@style/Widget.Ahc.Button.Tonal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:text="@string/show_qr_multi" />

                        <ImageView
                            android:id="@+id/image_qr"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="@dimen/space_md"
                            android:adjustViewBounds="true"
                            android:contentDescription="@string/qr_code" />

                        <TextView
                            android:id="@+id/text_sync_latest"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/ahc_gold" />

                        <EditText
                            android:id="@+id/edit_sync_code"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_md"
                            android:backgroundTint="@color/ahc_outline"
                            android:gravity="top|start"
                            android:hint="@string/paste_code_hint"
                            android:importantForAutofill="no"
                            android:inputType="text|textMultiLine|textNoSuggestions"
                            android:minLines="3"
                            android:textColor="@color/ahc_text"
                            android:textColorHint="@color/ahc_text_muted" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_import_code"
                            style="@style/Widget.Ahc.Button"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_md"
                            android:text="@string/import_code" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_export_code"
                            style="@style/Widget.Ahc.Button.Tonal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:text="@string/export_code" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_copy_code"
                            style="@style/Widget.Ahc.Button.Text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/copy_to_clipboard" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_nfc"
                    style="@style/Widget.Ahc.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    app:cardUseCompatPadding="false"
                    app:contentPadding="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_md">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/section_nfc"
                            android:textAppearance="?attr/textAppearanceTitleLarge"
                            android:textColor="@color/ahc_text" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:text="@string/section_nfc_help"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/ahc_text_muted" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_nfc_prepare"
                            style="@style/Widget.Ahc.Button"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_md"
                            android:text="@string/nfc_prepare_push" />

                        <TextView
                            android:id="@+id/text_nfc_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/ahc_text_muted" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_play"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Ahc.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_md">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/section_play"
                            android:textAppearance="?attr/textAppearanceTitleLarge"
                            android:textColor="@color/ahc_text" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:text="@string/section_play_help"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/ahc_text_muted" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_play_winlator"
                            style="@style/Widget.Ahc.Button"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_md"
                            android:text="@string/open_winlator" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_open_winlator"
                            style="@style/Widget.Ahc.Button.Tonal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:text="@string/android_open_winlator_project" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:text="@string/android_see_docs"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/ahc_text_muted" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Ahc.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    app:cardUseCompatPadding="false"
                    app:contentPadding="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_sm">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/section_library"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="@color/ahc_text" />

                        <TextView
                            android:id="@+id/text_tree_uri"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/no_tree_yet"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/ahc_text_muted" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_pick_tree"
                            style="@style/Widget.Ahc.Button.Tonal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:text="@string/choose_synastria_folder" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_scan_snapshot"
                            style="@style/Widget.Ahc.Button.Tonal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:text="@string/scan_attune_snapshot" />

                        <TextView
                            android:id="@+id/text_scan_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/ahc_text_muted" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

        <LinearLayout
            android:id="@+id/section_attunes"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="@dimen/content_padding_compact"
            android:paddingEnd="@dimen/content_padding_compact"
            android:paddingTop="@dimen/space_xs"
            android:paddingBottom="@dimen/space_xs"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_attunes_graph"
                style="@style/Widget.Ahc.Card.Highlight"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                app:cardUseCompatPadding="false"
                app:contentPadding="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="@dimen/space_sm">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/section_attunes_history"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/ahc_cyan" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:overScrollMode="never"
                        android:scrollbars="none">

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chip_group_attune_metric"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:chipSpacingHorizontal="@dimen/space_xs"
                            app:selectionRequired="true"
                            app:singleLine="true"
                            app:singleSelection="true">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_attune_m_account"
                                style="@style/Widget.Ahc.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true"
                                android:text="@string/graph_metric_account" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_attune_m_tf"
                                style="@style/Widget.Ahc.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/graph_metric_tf" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_attune_m_wf"
                                style="@style/Widget.Ahc.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/graph_metric_wf" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_attune_m_lf"
                                style="@style/Widget.Ahc.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/graph_metric_lf" />
                        </com.google.android.material.chip.ChipGroup>
                    </HorizontalScrollView>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:overScrollMode="never"
                        android:scrollbars="none">

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chip_group_attune_display"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:chipSpacingHorizontal="@dimen/space_xs"
                            app:selectionRequired="true"
                            app:singleLine="true"
                            app:singleSelection="true">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_attune_d_bars"
                                style="@style/Widget.Ahc.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/graph_display_bars" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_attune_d_plot"
                                style="@style/Widget.Ahc.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true"
                                android:text="@string/graph_display_plot" />
                        </com.google.android.material.chip.ChipGroup>
                    </HorizontalScrollView>

                    <TextView
                        android:id="@+id/text_attune_graph_detail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:fontFamily="monospace"
                        android:textColor="@color/ahc_text"
                        android:textIsSelectable="true"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/text_attune_graph_average"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:gravity="center"
                        android:textColor="@color/ahc_gold"
                        android:textSize="16sp" />

                    <com.attunehelper.companion.attune.graph.AttuneGraphView
                        android:id="@+id/attune_graph"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginTop="@dimen/space_xs"
                        android:minHeight="120dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_attunes_intro"
                style="@style/Widget.Ahc.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                app:cardUseCompatPadding="false"
                app:contentPadding="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_sm">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/section_attunes_chart"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/ahc_text" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/section_attunes_chart_help"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/ahc_text_muted" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_attunes_open_sync"
                        style="@style/Widget.Ahc.Button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:text="@string/attunes_open_sync" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
